<Window x:Class="TireShopAccounting.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:vm="clr-namespace:TireShopAccounting.UI.ViewModels"
        xmlns:views="clr-namespace:TireShopAccounting.UI.Views"
        Title="سیستم حسابداری لاستیک فروشی" 
        Height="768" 
        Width="1366"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        FontFamily="Vazir"
        FontSize="14"
        Background="#f3eadd">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductViewModel}">
            <views:ProductsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InvoiceViewModel}">
            <views:InvoiceView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#31241d" Padding="20,0">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="سیستم حسابداری لاستیک فروشی" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="{Binding Source={x:Static System:DateTime.Today}, StringFormat='تاریخ: {0:yyyy/MM/dd}'}" 
                               FontSize="14" 
                               Foreground="#c6ad8b"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="#31241d" Padding="0">
            <StackPanel Margin="0,20,0,0">
                
                <!-- داشبورد -->
                <Button Command="{Binding ShowDashboardCommand}"
                        Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="داشبورد" FontSize="16"/>
                    </StackPanel>
                </Button>
                
                <!-- کالاها -->
                <Button Command="{Binding ShowProductsCommand}"
                        Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="کالاها" FontSize="16"/>
                    </StackPanel>
                </Button>
                
                <!-- مشتریان -->
                <Button Command="{Binding ShowCustomersCommand}"
                        Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="مشتریان" FontSize="16"/>
                    </StackPanel>
                </Button>
                
                <!-- فاکتور -->
                <Button Command="{Binding ShowInvoiceCommand}"
                        Style="{StaticResource MenuButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧾" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="فاکتور فروش" FontSize="16"/>
                    </StackPanel>
                </Button>
                
                <!-- پشتیبان‌گیری -->
                <Button Click="BackupButton_Click"
                        Style="{StaticResource MenuButtonStyle}"
                        Margin="0,40,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="پشتیبان‌گیری" FontSize="16"/>
                    </StackPanel>
                </Button>
                
            </StackPanel>
        </Border>
        
        <!-- Content Area -->
        <Border Grid.Row="1" Grid.Column="1" Background="#f3eadd" Padding="20">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
