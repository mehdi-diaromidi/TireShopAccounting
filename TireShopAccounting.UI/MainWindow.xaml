<Window x:Class="TireShopAccounting.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:vm="clr-namespace:TireShopAccounting.UI.ViewModels"
        xmlns:views="clr-namespace:TireShopAccounting.UI.Views"
        Title="سیستم حسابداری لاستیک فروشی" 
        Height="768" 
        Width="1366"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        FontFamily="Vazir"
        FontSize="13"
        Background="#F3F4F6">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductViewModel}">
            <views:ProductsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InvoiceViewModel}">
            <views:InvoiceView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource DarkColor}" Padding="20,0">
            <DockPanel LastChildFill="False" FlowDirection="RightToLeft">
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="سیستم حسابداری لاستیک فروشی"
                               TextAlignment="Right"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding PersianDate}"
                               TextAlignment="Right"
                               FontSize="12"
                               Foreground="{StaticResource AccentColor}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource DarkColor}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,16,0,0">
                    
                    <!-- داشبورد -->
                    <Button Command="{Binding ShowDashboardCommand}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                            <TextBlock Text="داشبورد" TextAlignment="Right" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="📊" FontSize="18"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- کالاها -->
                    <Button Command="{Binding ShowProductsCommand}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                            <TextBlock Text="کالاها" TextAlignment="Right" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="📦" FontSize="18"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- مشتریان -->
                    <Button Command="{Binding ShowCustomersCommand}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                            <TextBlock Text="مشتریان" TextAlignment="Right" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="👥" FontSize="18"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- فاکتور -->
                    <Button Command="{Binding ShowInvoiceCommand}"
                            Style="{StaticResource MenuButtonStyle}">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                            <TextBlock Text="فاکتور فروش" TextAlignment="Right" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="🧾" FontSize="18"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- پشتیبان‌گیری -->
                    <Button Click="BackupButton_Click"
                            Style="{StaticResource MenuButtonStyle}"
                            Margin="8,32,8,4">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                            <TextBlock Text="پشتیبان‌گیری" TextAlignment="Right" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="💾" FontSize="18"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>

                <Border Grid.Row="1" Margin="12,8,12,12" Padding="8" CornerRadius="6" Background="#253247">
                    <TextBlock Text="توسعه داده شده توسط محمد مهدی دیارامیدی | 09932208665"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="11"
                               Foreground="#D1D5DB"/>
                </Border>
            </Grid>
        </Border>
        
        <!-- Content Area -->
        <Border Grid.Row="1" Grid.Column="1" Background="#F3F4F6" Padding="20">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
