<UserControl x:Class="TireShopAccounting.UI.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- لیست کالاها -->
        <GroupBox Grid.Column="0" Header="📦 لیست کالاها" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- جستجو -->
                <TextBox Grid.Row="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         TextAlignment="Right"
                         Margin="0,0,0,12">
                    <TextBox.Resources>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Right">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="🔍 جستجو..." 
                                                             Foreground="#9CA3AF" 
                                                             Margin="10,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                
                <!-- DataGrid -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Products}" 
                          SelectedItem="{Binding SelectedProduct}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نام کالا" Binding="{Binding Name}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="برند" Binding="{Binding Brand}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="موجودی" Binding="{Binding Quantity}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="قیمت خرید" Binding="{Binding BuyPrice, StringFormat='{}{0:N0}'}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="قیمت فروش" Binding="{Binding SellPrice, StringFormat='{}{0:N0}'}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
        
        <!-- فرم افزودن/ویرایش -->
        <GroupBox Grid.Column="1" Header="➕ افزودن/ویرایش کالا">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    
                    <Label Content="نام کالا:"/>
                    <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <Label Content="برند:"/>
                    <TextBox Text="{Binding ProductBrand, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <Label Content="موجودی:"/>
                    <TextBox Text="{Binding ProductQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <Label Content="قیمت خرید (تومان):"/>
                    <TextBox Text="{Binding BuyPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <Label Content="قیمت فروش (تومان):"/>
                    <TextBox Text="{Binding SellPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <!-- دکمه‌ها -->
                    <StackPanel Margin="0,20,0,0">
                        <Button Content="💾 ذخیره" 
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                        
                        <Button Content="➕ جدید" 
                                Command="{Binding AddNewCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                        
                        <Button Content="🗑️ حذف" 
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                        
                        <Button Content="❌ انصراف" 
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</UserControl>
