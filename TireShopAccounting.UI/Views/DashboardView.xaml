<UserControl x:Class="TireShopAccounting.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            
            <!-- عنوان -->
            <TextBlock Text="داشبورد" FontSize="32" FontWeight="Bold" Foreground="#31241d" Margin="0,0,0,20"/>
            
            <!-- کارت‌های خلاصه -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- فروش امروز -->
                <Border Grid.Column="0" Background="#04256b" CornerRadius="15" Padding="25" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="فروش امروز" FontSize="18" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TodaySales, StringFormat='{}{0:N0} تومان'}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="#c6ad8b" 
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- تعداد کالاها -->
                <Border Grid.Column="1" Background="#c6ad8b" CornerRadius="15" Padding="25" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="تعداد کالاها" FontSize="18" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalProducts, StringFormat='{}{0} قلم'}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="#31241d" 
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- تعداد مشتریان -->
                <Border Grid.Column="2" Background="#31241d" CornerRadius="15" Padding="25" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="تعداد مشتریان" FontSize="18" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCustomers, StringFormat='{}{0} نفر'}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="#c6ad8b" 
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- هشدار موجودی کم -->
            <GroupBox Header="⚠️ هشدار موجودی کم" BorderBrush="#dc3545" Foreground="#dc3545">
                <Grid>
                    <TextBlock Text="موجودی تمام کالاها کافی است ✅" 
                               FontSize="16" 
                               Foreground="#28a745"
                               HorizontalAlignment="Center"
                               Margin="0,10"
                               Visibility="{Binding LowStockProducts.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                    
                    <DataGrid ItemsSource="{Binding LowStockProducts}"
                              Visibility="{Binding LowStockProducts.Count, Converter={StaticResource InverseCountToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="نام کالا" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="برند" Binding="{Binding Brand}" Width="*"/>
                            <DataGridTextColumn Header="موجودی فعلی" Binding="{Binding Quantity}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#dc3545"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
            
            <!-- دکمه بروزرسانی -->
            <Button Content="🔄 بروزرسانی داشبورد" 
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Width="200"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
