<UserControl x:Class="TireShopAccounting.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            
            <!-- عنوان -->
            <TextBlock Text="داشبورد" FontSize="26" FontWeight="Bold" Foreground="{StaticResource DarkColor}" Margin="0,0,0,16"/>
            
            <!-- کارت‌های خلاصه -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- فروش امروز -->
                <Border Grid.Column="0" Background="{StaticResource PrimaryColor}" CornerRadius="12" Padding="20" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="فروش امروز" FontSize="15" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TodaySales, StringFormat='{}{0:N0} تومان'}" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource AccentColor}" 
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- تعداد کالاها -->
                <Border Grid.Column="1" Background="{StaticResource SecondaryColor}" CornerRadius="12" Padding="20" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="تعداد کالاها" FontSize="15" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalProducts, StringFormat='{}{0} قلم'}" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- تعداد مشتریان -->
                <Border Grid.Column="2" Background="{StaticResource DarkColor}" CornerRadius="12" Padding="20" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="تعداد مشتریان" FontSize="15" Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCustomers, StringFormat='{}{0} نفر'}" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource AccentColor}" 
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- وضعیت موجودی کالاها -->
            <GroupBox Header="⚠️ وضعیت موجودی کالاها" BorderBrush="{StaticResource WarningColor}" Foreground="{StaticResource WarningColor}">
                <Grid>
                    <TextBlock Text="موجودی تمام کالاها کافی است ✅" 
                               FontSize="14" 
                               Foreground="{StaticResource SuccessColor}"
                               HorizontalAlignment="Center"
                               Margin="0,8"
                               Visibility="{Binding LowStockProducts.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                    
                    <DataGrid ItemsSource="{Binding LowStockProducts}"
                              Visibility="{Binding LowStockProducts.Count, Converter={StaticResource InverseCountToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="نام کالا" Binding="{Binding Name}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="برند" Binding="{Binding Brand}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="موجودی فعلی" Binding="{Binding Quantity}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
            
            <!-- دکمه بروزرسانی -->
            <Button Content="🔄 بروزرسانی داشبورد" 
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"
                    Width="180"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
