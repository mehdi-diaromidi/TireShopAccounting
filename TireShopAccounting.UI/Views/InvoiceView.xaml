<UserControl x:Class="TireShopAccounting.UI.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- عنوان -->
        <TextBlock Grid.Row="0" Text="🧾 فاکتور فروش" FontSize="26" FontWeight="Bold" Foreground="{StaticResource DarkColor}" Margin="0,0,0,16"/>
        
        <!-- انتخاب مشتری و کالا -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Label Content="انتخاب مشتری:"/>
                <ComboBox ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="Name"
                          Foreground="#1F2937"
                          Background="White"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <Label Content="جستجو و انتخاب کالا:"/>
                <ComboBox ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          DisplayMemberPath="DisplayName"
                          IsTextSearchEnabled="True"
                          TextSearch.TextPath="DisplayName"
                          IsEditable="True"
                          Text="{Binding SearchProductText, UpdateSourceTrigger=PropertyChanged}"
                          Foreground="#1F2937"
                          Background="White"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                <Label Content="تعداد:"/>
                <TextBox Text="{Binding ItemQuantity, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            
            <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                <Button Content="➕ افزودن" 
                        Command="{Binding AddItemCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="110"/>
            </StackPanel>
        </Grid>
        
        <!-- لیست اقلام فاکتور -->
        <GroupBox Grid.Row="2" Header="📋 اقلام فاکتور" Margin="0,0,0,16">
            <DataGrid ItemsSource="{Binding InvoiceItems}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="نام کالا" Binding="{Binding Product.DisplayName}" Width="2*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="تعداد" Binding="{Binding Quantity}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="قیمت واحد" Binding="{Binding Price, StringFormat='{}{0:N0}'}" Width="140" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="قیمت کل" Binding="{Binding TotalPrice, StringFormat='{}{0:N0}'}" Width="140" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="عملیات" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑️" 
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Height="32"
                                        Width="55"
                                        Margin="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        
        <!-- جمع کل و دکمه‌ها -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- دکمه‌ها -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="💾 ثبت فاکتور" 
                        Command="{Binding SaveInvoiceCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="140"/>
                
                <Button Content="🖨️ چاپ آخرین فاکتور" 
                        Command="{Binding PrintInvoiceCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="180"/>
                
                <Button Content="🗑️ پاک کردن" 
                        Command="{Binding ClearInvoiceCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        Width="130"/>
            </StackPanel>
            
            <!-- اطلاعات مالی -->
            <Border Grid.Column="1" Background="{StaticResource DarkColor}" CornerRadius="8" Padding="18" MinWidth="340">
                <StackPanel FlowDirection="RightToLeft">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="جمع کل:" FontSize="14" Foreground="White" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{}{0:N0} تومان'}" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource AccentColor}" 
                                   HorizontalAlignment="Left"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="تخفیف:" FontSize="14" Foreground="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="140"
                                 HorizontalAlignment="Left"
                                 Height="32"/>
                    </Grid>
                    
                    <Separator Background="{StaticResource AccentColor}" Margin="0,4"/>
                    
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="مبلغ قابل پرداخت:" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,12,0"/>
                        <Border Grid.Column="1" Background="White" CornerRadius="4" Padding="10,6" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding FinalAmount, StringFormat='{}{0:N0} تومان'}" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource PrimaryColor}"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
